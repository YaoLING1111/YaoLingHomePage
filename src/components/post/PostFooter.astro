---
import { getSortedPosts } from '@lib/content';
import { toPostRefWithCategory } from '@lib/content/transforms';
import { getLocaleFromUrl } from '@/i18n';
import RandomPostList from './RandomPostList';

const locale = getLocaleFromUrl(Astro.url.pathname);

// Get all posts
const allPosts = await getSortedPosts(locale);
const totalPosts = allPosts.length;

// Calculate how many posts to show on each side
// Keep the article footer very compact: only 2 random posts.
const randomCount = Math.min(2, totalPosts);

// Prepare post pools for client-side randomization
const allPostItems = allPosts.map(toPostRefWithCategory);
---

<div class="mx-auto max-w-3xl px-10 md:px-6">
  <RandomPostList client:only="react" postsPool={allPostItems} count={randomCount} locale={locale} />
</div>
